# ============================================================
# ZanAlytics — Environment Variables
# Скопируйте в .env и настройте под свое окружение
# ============================================================

# === Ollama (LLM) ===
# URL Ollama API (для Docker используется host.docker.internal)
ZAN_OLLAMA_URL=http://localhost:11434
# Модель для анализа текста
ZAN_OLLAMA_MODEL=qwen2.5:14b
# Модель для эмбеддингов
ZAN_OLLAMA_EMBED_MODEL=nomic-embed-text

# === Хранилища данных (пути относительно backend/) ===
ZAN_DB_PATH=data/zandb.sqlite
ZAN_CHROMA_PATH=data/chroma
ZAN_RAW_HTML_PATH=data/raw_html

# === Парсер adilet.zan.kz ===
# Базовый URL сайта
ZAN_ADILET_BASE_URL=https://adilet.zan.kz
# Максимум запросов в секунду
ZAN_SCRAPER_RATE_LIMIT=2
# Проверка SSL (у adilet.zan.kz бывают проблемы с сертификатом)
ZAN_SCRAPER_SSL_VERIFY=false

# === Пороги анализа ===
# Порог cosine similarity для определения дублирования (0.0-1.0)
ZAN_SIMILARITY_THRESHOLD=0.85
# Минимальная уверенность LLM для фиксации противоречия (0.0-1.0)
ZAN_CONTRADICTION_CONFIDENCE_MIN=0.6

# === Параметры LLM ===
ZAN_LLM_TEMPERATURE_ANALYSIS=0.1
ZAN_LLM_TEMPERATURE_EXPLAIN=0.3
ZAN_LLM_MAX_TOKENS_EXPLAIN=1000
ZAN_LLM_MAX_TOKENS_CLASSIFY=500

# === API ===
# Размер страницы для пагинации
ZAN_API_PAGE_SIZE=20
# CORS — разрешенные origins (JSON-массив)
ZAN_CORS_ORIGINS=["http://localhost:3100","http://localhost:3300"]

# === Frontend ===
# URL бэкенда для клиентских запросов из браузера
NEXT_PUBLIC_API_URL=http://localhost:8000
